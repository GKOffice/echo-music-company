# ============================================
# Melodio — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git
# ============================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://echo:echo_dev@localhost:5432/echo
REDIS_URL=redis://localhost:6379

# --- Auth ---
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# --- AI ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Payments ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# --- Streaming Platforms ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=
SOUNDCLOUD_CLIENT_ID=

# --- Distribution ---
DISTROKID_API_KEY=

# --- WhatsApp ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Storage (AWS S3 / Cloudflare R2) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=echo-assets
AWS_REGION=us-west-2

# --- Social ---
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# --- Email ---
SENDGRID_API_KEY=

# --- Analytics ---
CHARTMETRIC_API_KEY=

# --- KYC ---
PERSONA_API_KEY=

# --- App ---
ENVIRONMENT=development
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
# Production: https://melodio.io
NEXT_PUBLIC_API_URL=http://localhost:8000
